# ─── Contact API ────────────────────────────────────────────────────────────────

# Resend (https://resend.com) — used to send contact form and waitlist emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address(es) that receive contact form submissions.
# Use a comma-separated list to notify multiple recipients:
#   CONTACT_EMAIL=alice@example.com, bob@example.com
CONTACT_EMAIL=you@yourdomain.com

# Telegram Bot (https://core.telegram.org/bots) — alternative/parallel notification channel
# Create a bot via @BotFather and get the token
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The Telegram chat ID to send messages to (use @userinfobot to find yours)
TELEGRAM_CHAT_ID=123456789

# ─── Landing Page ─────────────────────────────────────────────────────────────

# Required (if you are not serving an APK from /public/downloads): external APK URL for download buttons + QR code.
# Example (GitHub Releases):
# NEXT_PUBLIC_APK_URL=https://github.com/<owner>/<repo>/releases/latest/download/unipool.apk
NEXT_PUBLIC_APK_URL=